# Example environment for CodeRunBot (systemd --user)
# Place this at: ~/.config/environment.d/coderunbot.env
# or copy keys into a local .env file outside version control.

# ---- Discord tokens ----
CODERUNBOT_TOKEN=
GAATO_BOT_TOKEN=

# ---- Optional features ----
OPENAI_API_KEY=
WOLFRAM_APPID=
# GOOGLE_API_KEY=  # mentioned in README; may be unused depending on enabled cogs

# ---- TeX renderer endpoint ----
# TEX_BASE_URL defaults to http://127.0.0.1:8080 when unset
TEX_BASE_URL=http://127.0.0.1:8080
